# Supabase (Replace with your actual project values)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Mapbox (Obtain from mapbox.com)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token

# App URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Migration (Used by npm run migrate)
MIGRATION_ADMIN_PASSWORD=admin-password-here
MIGRATION_DEFAULT_PASSWORD=inspector-password-here
